# Backend environment example for SproutSense
# Copy this to backend/.env (local) or set equivalent values in your deployment platform.

# Core server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/smart-watering

# CORS
CORS_ORIGIN=http://localhost:5173

# Test mode and rate limits
ENABLE_TEST_MODE=true
RATE_LIMIT_MAX=200

# ESP32 connectivity
ESP32_IP=192.168.1.100
ESP32_PORT=80

# AI and weather provider selection
AI_PRIMARY_PROVIDER=gemini
WEATHER_PRIMARY=openweathermap
WEATHER_LOCATION=auto

# API keys (leave blank if not used)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=
OPEN_METEO_KEY=
WEATHERAPI_FREE_KEY=

# Security
JWT_SECRET=replace-with-a-strong-secret
