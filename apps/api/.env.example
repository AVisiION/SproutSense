# Backend environment variables for local/prod deployment
NODE_ENV=production
PORT=5000

# Required in production; include database name in URI path
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sproutsense?retryWrites=true&w=majority

# Comma-separated allowed frontend origins
CORS_ORIGIN=https://your-site.netlify.app

# Public frontend URL used in verification and reset emails
FRONTEND_URL=https://your-site.netlify.app

# Admin IP whitelist (comma-separated: never rate-limited or account-locked)
ADMIN_IPS=localhost,127.0.0.1,::1

# SMTP mail delivery configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SproutSense <no-reply@your-domain.com>

# Optional legacy alias used by some docs/deploy setups
CLIENT_URL=https://your-site.netlify.app

# Optional AI provider keys
GEMINI_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# Optional weather provider keys
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=

# Optional bootstrap admin login (created/synced at startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=System Administrator
# Set true only when you intentionally want to reset ADMIN_PASSWORD on every startup
ADMIN_FORCE_PASSWORD_UPDATE=false
