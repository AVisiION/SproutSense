# Frontend environment example for SproutSense
# Copy to web/.env for local development.

# API base used by axios/fetch calls
VITE_API_BASE_URL=http://localhost:5000/api

# Optional explicit WebSocket endpoint.
# If omitted, the app derives ws/wss from VITE_API_BASE_URL.
VITE_WS_URL=ws://localhost:5000/ws
